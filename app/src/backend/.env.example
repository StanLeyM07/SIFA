# ── Server ────────────────────────────────────────────────────
PORT=3001

# Comma-separated list of browser origins allowed to call the API.
# MUST be set in production — a wildcard would leave the only endpoint that
# costs money open to the whole internet.
FRONTEND_ORIGIN=http://localhost:5174

# ── LLM provider ──────────────────────────────────────────────
# Any OpenAI-compatible endpoint. Swap these three vars, change no code.
#
# Groq (fast and cheap — good default)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_YOUR_KEY_HERE
LLM_MODEL=llama-3.1-8b-instant

# OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=gpt-4o-mini

# NVIDIA NIM
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_API_KEY=nvapi-xxx
# LLM_MODEL=meta/llama-3.1-70b-instruct

# OpenRouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-xxx
# LLM_MODEL=meta-llama/llama-3.1-70b-instruct

# Local Ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1

# Hard ceiling on LLM calls per UTC day, across all users. The backstop that
# stops a runaway loop or a scraper turning into an invoice.
LLM_DAILY_CALL_LIMIT=500
